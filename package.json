{
  "name": "grok-build-community",
  "displayName": "Grok Build - Community",
  "description": "Community VS Code host for Grok Build — thin ACP client for `grok agent stdio`.",
  "version": "0.2.0",
  "publisher": "xai",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "grok",
    "grok-build",
    "xai",
    "agent",
    "acp",
    "community"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "grok",
          "title": "Grok Build",
          "icon": "media/grok.svg"
        }
      ],
      "secondarySidebar": [
        {
          "id": "grok-secondary",
          "title": "Grok Build",
          "icon": "media/grok.svg",
          "when": "!grok.doesNotSupportSecondarySidebar"
        }
      ]
    },
    "views": {
      "grok": [
        {
          "type": "webview",
          "id": "grok.chatView",
          "name": "Grok Build",
          "visibility": "visible"
        }
      ],
      "grok-secondary": [
        {
          "type": "webview",
          "id": "grok.chatView.secondary",
          "name": "Grok Build",
          "visibility": "visible",
          "when": "!grok.doesNotSupportSecondarySidebar"
        }
      ]
    },
    "commands": [
      {
        "command": "grok.openChat",
        "title": "Grok Build: Open Chat",
        "category": "Grok Build",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "grok.openChatActivityBar",
        "title": "Grok Build: Open Chat (Activity Bar)",
        "category": "Grok Build",
        "icon": "$(layout-sidebar-left)"
      },
      {
        "command": "grok.openOutput",
        "title": "Grok Build: Open Output",
        "category": "Grok Build"
      },
      {
        "command": "grok.startAgent",
        "title": "Grok Build: Start Agent",
        "category": "Grok Build"
      },
      {
        "command": "grok.restartAgent",
        "title": "Grok Build: Restart Agent",
        "category": "Grok Build"
      },
      {
        "command": "grok.stopAgent",
        "title": "Grok Build: Stop Agent",
        "category": "Grok Build"
      },
      {
        "command": "grok.newSession",
        "title": "Grok Build: New Session",
        "category": "Grok Build"
      },
      {
        "command": "grok.cancel",
        "title": "Grok Build: Cancel Turn",
        "category": "Grok Build"
      },
      {
        "command": "grok.login",
        "title": "Grok Build: Login / Set API Key",
        "category": "Grok Build"
      },
      {
        "command": "grok.setApiKey",
        "title": "Grok Build: Set API Key",
        "category": "Grok Build"
      },
      {
        "command": "grok.clearApiKey",
        "title": "Grok Build: Clear API Key",
        "category": "Grok Build"
      },
      {
        "command": "grok.addSelectionToChat",
        "title": "Grok Build: Add Selection to Chat",
        "category": "Grok Build"
      },
      {
        "command": "grok.addFileToChat",
        "title": "Grok Build: Add Active File to Chat",
        "category": "Grok Build"
      },
      {
        "command": "grok.smokeTest",
        "title": "Grok Build: Smoke Test (L0)",
        "category": "Grok Build"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "grok.newSession",
          "when": "view == grok.chatView || view == grok.chatView.secondary",
          "group": "navigation"
        },
        {
          "command": "grok.openOutput",
          "when": "view == grok.chatView || view == grok.chatView.secondary",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "grok.addSelectionToChat",
          "when": "editorHasSelection",
          "group": "grok@1"
        }
      ]
    },
    "configuration": {
      "title": "Grok Build",
      "properties": {
        "grok.binaryPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the `grok` binary. Empty = search PATH then `~/.grok/bin/grok`."
        },
        "grok.model": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional model id passed as `grok agent --model <id> stdio`."
        },
        "grok.alwaysApprove": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Pass `--always-approve` to the agent (auto-approve tools). Use only for trusted workspaces."
        },
        "grok.cwd": {
          "type": "string",
          "default": "",
          "markdownDescription": "Working directory for the agent session. Empty = first workspace folder, else process cwd."
        },
        "grok.initializeTimeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 5000,
          "markdownDescription": "Timeout for spawn + `initialize` before killing the agent process."
        },
        "grok.permissionTimeoutMs": {
          "type": "number",
          "default": 120000,
          "minimum": 5000,
          "markdownDescription": "How long to wait for a permission decision before auto-deny."
        },
        "grok.inheritEnvApiKey": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "If no SecretStorage key, pass `XAI_API_KEY` from the extension host environment."
        },
        "grok.ui.showThoughts": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Show agent thinking chunks in the chat panel."
        },
        "grok.context.autoAttachActiveFile": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Attach the active editor file as context on each prompt."
        },
        "grok.context.autoAttachSelection": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "When there is a non-empty selection, attach it instead of (or with) the full file link."
        },
        "grok.context.excludeGlob": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/.env",
            "**/.env.*",
            "**/secrets/**",
            "**/*credential*",
            "**/*.pem"
          ],
          "markdownDescription": "Do not auto-attach paths matching these patterns."
        },
        "grok.fs.preferOpenBuffers": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Host `fs/read_text_file` prefers unsaved editor buffers."
        },
        "grok.fs.autoSave": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Save after host `fs/write_text_file`."
        },
        "grok.fs.maxReadBytes": {
          "type": "number",
          "default": 5000000,
          "markdownDescription": "Max bytes for host file reads."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "compile": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package": "vsce package --no-dependencies",
    "smoke:cli": "node scripts/smoke-cli.mjs"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.2.1",
    "@tabler/icons-webfont": "^3.44.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.93.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.2"
  }
}
