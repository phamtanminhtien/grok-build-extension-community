{
  "name": "grok-build-community-edition",
  "displayName": "Grok Build Community Edition",
  "description": "Community VS Code host for Grok Build — thin ACP client for `grok agent stdio`. Requires the Grok Build CLI (`grok`) on PATH.",
  "version": "0.3.4",
  "packageManager": "yarn@4.12.0",
  "publisher": "tienpham",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/phamtanminhtien/grok-build-extension-community.git"
  },
  "bugs": {
    "url": "https://github.com/phamtanminhtien/grok-build-extension-community/issues"
  },
  "homepage": "https://github.com/phamtanminhtien/grok-build-extension-community#readme",
  "galleryBanner": {
    "color": "#0B0B0F",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "grok",
    "grok-build",
    "xai",
    "agent",
    "acp",
    "community"
  ],
  "qna": "marketplace",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "grok",
          "title": "Grok Build",
          "icon": "media/grok.svg"
        }
      ],
      "secondarySidebar": [
        {
          "id": "grok-secondary",
          "title": "Grok Build",
          "icon": "media/grok.svg",
          "when": "!grok.doesNotSupportSecondarySidebar"
        }
      ]
    },
    "views": {
      "grok": [
        {
          "type": "webview",
          "id": "grok.chatView",
          "name": "Grok Build",
          "visibility": "visible"
        }
      ],
      "grok-secondary": [
        {
          "type": "webview",
          "id": "grok.chatView.secondary",
          "name": "Grok Build",
          "visibility": "visible",
          "when": "!grok.doesNotSupportSecondarySidebar"
        }
      ]
    },
    "commands": [
      {
        "command": "grok.openChat",
        "title": "Grok Build: Open Chat",
        "category": "Grok Build",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "grok.openChatActivityBar",
        "title": "Grok Build: Open Chat (Activity Bar)",
        "category": "Grok Build",
        "icon": "$(layout-sidebar-left)"
      },
      {
        "command": "grok.openOutput",
        "title": "Grok Build: Open Output",
        "category": "Grok Build"
      },
      {
        "command": "grok.startAgent",
        "title": "Grok Build: Start Agent",
        "category": "Grok Build"
      },
      {
        "command": "grok.restartAgent",
        "title": "Grok Build: Restart Agent",
        "category": "Grok Build"
      },
      {
        "command": "grok.stopAgent",
        "title": "Grok Build: Stop Agent",
        "category": "Grok Build"
      },
      {
        "command": "grok.newSession",
        "title": "Grok Build: New Session",
        "category": "Grok Build",
        "icon": "$(add)"
      },
      {
        "command": "grok.cancel",
        "title": "Grok Build: Cancel Turn",
        "category": "Grok Build"
      },
      {
        "command": "grok.login",
        "title": "Grok Build: Login",
        "category": "Grok Build"
      },
      {
        "command": "grok.logout",
        "title": "Grok Build: Logout",
        "category": "Grok Build"
      },
      {
        "command": "grok.setApiKey",
        "title": "Grok Build: Set API Key",
        "category": "Grok Build"
      },
      {
        "command": "grok.clearApiKey",
        "title": "Grok Build: Clear API Key",
        "category": "Grok Build"
      },
      {
        "command": "grok.addSelectionToChat",
        "title": "Grok Build: Add Selection to Chat",
        "category": "Grok Build"
      },
      {
        "command": "grok.addFileToChat",
        "title": "Grok Build: Add Active File to Chat",
        "category": "Grok Build"
      },
      {
        "command": "grok.addContext",
        "title": "Grok Build: Add Context…",
        "category": "Grok Build",
        "icon": "$(mention)"
      },
      {
        "command": "grok.selectModel",
        "title": "Grok Build: Select Model",
        "category": "Grok Build"
      },
      {
        "command": "grok.resumeSession",
        "title": "Grok Build: Resume Session…",
        "category": "Grok Build",
        "icon": "$(history)"
      },
      {
        "command": "grok.reviewEdits",
        "title": "Grok Build: Review Edits…",
        "category": "Grok Build",
        "icon": "$(diff)"
      },
      {
        "command": "grok.openExtensions",
        "title": "Grok Build: Extensions…",
        "category": "Grok Build",
        "icon": "$(extensions)"
      },
      {
        "command": "grok.smokeTest",
        "title": "Grok Build: Smoke Test (L0)",
        "category": "Grok Build"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "grok.newSession",
          "when": "view == grok.chatView || view == grok.chatView.secondary",
          "group": "navigation@1"
        },
        {
          "command": "grok.resumeSession",
          "when": "view == grok.chatView || view == grok.chatView.secondary",
          "group": "navigation@2"
        },
        {
          "command": "grok.reviewEdits",
          "when": "view == grok.chatView || view == grok.chatView.secondary",
          "group": "navigation@3"
        },
        {
          "command": "grok.openExtensions",
          "when": "view == grok.chatView || view == grok.chatView.secondary",
          "group": "navigation@4"
        }
      ],
      "editor/context": [
        {
          "command": "grok.addSelectionToChat",
          "when": "editorHasSelection",
          "group": "grok@1"
        }
      ]
    },
    "configuration": {
      "title": "Grok Build",
      "properties": {
        "grok.binaryPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path to the `grok` binary. Empty = search PATH then `~/.grok/bin/grok`."
        },
        "grok.cwd": {
          "type": "string",
          "default": "",
          "markdownDescription": "Working directory for the agent session. Empty = first workspace folder, else process cwd."
        },
        "grok.initializeTimeoutMs": {
          "type": "number",
          "default": 30000,
          "minimum": 5000,
          "markdownDescription": "Timeout for spawn + `initialize` before killing the agent process."
        },
        "grok.permissionTimeoutMs": {
          "type": "number",
          "default": 120000,
          "minimum": 5000,
          "markdownDescription": "How long to wait for a permission decision before auto-deny."
        },
        "grok.inheritEnvApiKey": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "If no SecretStorage key, pass `XAI_API_KEY` from the extension host environment."
        },
        "grok.ui.showThoughts": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Show agent thinking chunks in the chat panel."
        },
        "grok.context.autoAttachActiveFile": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Attach the active editor file as context on each prompt."
        },
        "grok.context.autoAttachSelection": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "When there is a non-empty selection, attach it instead of (or with) the full file link."
        },
        "grok.context.excludeGlob": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/.env",
            "**/.env.*",
            "**/secrets/**",
            "**/*credential*",
            "**/*.pem"
          ],
          "markdownDescription": "Do not auto-attach paths matching these patterns."
        },
        "grok.fs.preferOpenBuffers": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Host `fs/read_text_file` prefers unsaved editor buffers."
        },
        "grok.fs.autoSave": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Save after host `fs/write_text_file` so agent edits do not leave files dirty/unsaved."
        },
        "grok.fs.maxReadBytes": {
          "type": "number",
          "default": 5000000,
          "markdownDescription": "Max bytes for host file reads."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "yarn build",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "compile": "yarn build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node scripts/run-tests.mjs",
    "package": "vsce package --no-dependencies",
    "publish:ovsx": "node -e \"const {execSync}=require('node:child_process');const p=require('./package.json');execSync('npx --yes ovsx publish '+p.name+'-'+p.version+'.vsix',{stdio:'inherit'})\"",
    "publish:vsce": "vsce publish --no-dependencies",
    "smoke:cli": "node scripts/smoke-cli.mjs"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^1.2.1",
    "@tabler/icons-webfont": "^3.44.0",
    "marked": "^15.0.12",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.93.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.2"
  }
}
